<?xml version="1.0" encoding="utf-8"?>
<!-- Figma: Purple → Blue gradient card (Total Balance, Add Expense button etc.) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="@color/primary_color"
        android:centerColor="@color/primary_light"
        android:endColor="@color/accent_color"
        android:angle="135"
        android:type="linear" />
    <corners android:radius="24dp" />
</shape>