<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/card_background"
            android:src="@drawable/ic_back"
            android:elevation="2dp"
            android:layout_marginEnd="16dp"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change PIN"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/top_bar"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current PIN"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_old_pin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/card_background"
                android:inputType="numberPassword"
                android:paddingHorizontal="16dp"
                android:maxLength="6"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New PIN"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_new_pin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/card_background"
                android:inputType="numberPassword"
                android:paddingHorizontal="16dp"
                android:maxLength="6"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm New PIN"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_confirm_new_pin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/card_background"
                android:inputType="numberPassword"
                android:paddingHorizontal="16dp"
                android:maxLength="6"
                android:layout_marginBottom="40dp" />

            <Button
                android:id="@+id/btn_update_pin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/gradient_card_background"
                android:text="Update PIN"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:elevation="4dp" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
